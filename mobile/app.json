{
  "expo": {
    "name": "Line Reader",
    "slug": "line-reader",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "line-reader",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.linereader.app",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Line Reader uses speech recognition to listen to your line delivery during rehearsal.",
        "NSMicrophoneUsageDescription": "Line Reader needs microphone access for speech recognition during rehearsal."
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
